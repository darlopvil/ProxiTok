{
    "name": "pablouser1/proxitok",
    "description": "An alternative frontend for TikTok",
    "version": "2.5.0.0",
    "license": "AGPL-3.0-or-later",
    "type": "project",
    "authors": [
        {
            "name": "Pablo Ferreiro",
            "homepage": "https://github.com/pablouser1"
        }
    ],
    "homepage": "https://github.com/pablouser1/ProxiTok",
    "repositories": [
        { "type": "vcs", "url": "https://github.com/darlopvil/TikScraperPHP" }
    ],
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "8.1"
        }
    },
    "require": {
        "php": "^8.1",
        "ext-mbstring": "*",
        "latte/latte": "^3.0",
        "bramus/router": "^1.6",
        "pablouser1/tikscraper": "dev-master",
        "josegonzalez/dotenv": "^4.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "suggest": {
        "ext-redis": "For using redis as a caching engine"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    }
}